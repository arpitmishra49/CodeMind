# =============================================================================
# CodeMind AI — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# -----------------------------------------------------------------------------
# LLM Provider — set ONE of the three options below
# -----------------------------------------------------------------------------

# Which provider to use: "gemini" | "openai" | "ollama"
LLM_PROVIDER=gemini

# -----------------------------------------------------------------------------
# OPTION 1: Gemini (FREE — Recommended)
# -----------------------------------------------------------------------------
# Get your free key at: https://aistudio.google.com/app/apikey
# Free tier: 15 requests/min, 1M tokens/day — more than enough
#
GOOGLE_API_KEY=AIzaSyAiWGIKvC7uylQnjqTlyUDNAqzjjHm52Xg

# Model options:
#   gemini-1.5-flash  → Fast, free, great for most queries  ✅ recommended
#   gemini-1.5-pro    → Smarter but only 50 requests/day on free tier
#   gemini-2.0-flash  → Latest, also free
GEMINI_MODEL=gemini-1.5-flash

# Embedding model (free)
GEMINI_EMBEDDING_MODEL=models/embedding-001

# -----------------------------------------------------------------------------
# OPTION 2: OpenAI (Paid — Best quality)
# -----------------------------------------------------------------------------
# Get your key at: https://platform.openai.com/api-keys
# Comment out Gemini lines above and uncomment these:
#
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-proj-your-openai-key-here
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# -----------------------------------------------------------------------------
# OPTION 3: Ollama (FREE — Fully local, no internet)
# -----------------------------------------------------------------------------
# Install: https://ollama.ai  then run: ollama pull llama3
# Comment out Gemini lines above and uncomment these:
#
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# -----------------------------------------------------------------------------
# GitHub Token (Optional)
# -----------------------------------------------------------------------------
# Needed for: private repos, avoiding rate limits (60→5000 req/hr)
# Get at: https://github.com/settings/tokens
# Scopes needed: repo (private) OR public_repo (public only)
#
GITHUB_TOKEN=

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
APP_NAME=CodeMind AI
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO

HOST=0.0.0.0
PORT=8000

# Frontend URL — change if running frontend on a different port
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# -----------------------------------------------------------------------------
# Vector Store & Chunking
# -----------------------------------------------------------------------------
FAISS_INDEX_PATH=./data/faiss_indexes
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
MAX_CHUNKS_PER_FILE=100
RETRIEVAL_K=8
RETRIEVAL_SCORE_THRESHOLD=0.3

# -----------------------------------------------------------------------------
# File Processing Limits
# -----------------------------------------------------------------------------
MAX_FILE_SIZE_MB=10
TEMP_DIR=./data/temp
MAX_REPO_SIZE_MB=500

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# Generate a strong secret: openssl rand -hex 32
SECRET_KEY=change-this-to-a-random-string-in-production
RATE_LIMIT_PER_MINUTE=60
